<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Adicionar Refeição"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etMealName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nome da refeição"
        android:inputType="textCapSentences"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etMealCalories"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Calorias (kcal)"
        android:inputType="number"
        android:layout_marginBottom="8dp"/>

    <CheckBox
        android:id="@+id/cbEstimateCalories"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Estimar Calorias"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:id="@+id/layoutCalorieEstimate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etMealDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:hint="Descreva a refeição e a porção"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="3"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnEstimateCalories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estimar"/>

    </LinearLayout>

    <Spinner
        android:id="@+id/spMealType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnSaveMeal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Salvar"/>

</LinearLayout>
